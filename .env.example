# Fill in the channels you want to use. Leave blank to skip.
# Only TG filled → Telegram only
# Only SMTP filled → Email only
# Both filled → both channels fire

# ── Telegram ──────────────────────────────────────
# Get token from @BotFather, chat_id from torchbell.setup()
TG_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TG_CHAT_ID=987654321

# ── Email ─────────────────────────────────────────
# Port 465 = SSL, 587 = STARTTLS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=yourname@gmail.com
SMTP_PASS=abcdefghijklmnop
SMTP_TO=recipient@example.com
